{
  "name": "@tvoy-box/api",
  "private": true,
  "version": "0.1.0",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "dev": "node --env-file=../../.env ../../node_modules/ts-node-dev/lib/bin.js --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../../.env dist/main.js",
    "prisma:db:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@prisma/client": "^6.8.2",
    "@tvoy-box/shared-config": "workspace:*",
    "@tvoy-box/shared-constants": "workspace:*",
    "@tvoy-box/shared-logger": "workspace:*",
    "@tvoy-box/shared-types": "workspace:*",
    "@tvoy-box/shared-utils": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^6.8.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
