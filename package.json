{
  "name": "tvoy-box-training-scheduler",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "corepack pnpm dev:api",
    "dev:api": "corepack pnpm --filter @tvoy-box/api dev",
    "dev:bot": "corepack pnpm --filter @tvoy-box/bot dev",
    "dev:mini-app": "corepack pnpm --filter @tvoy-box/mini-app dev",
    "dev:db:up": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/db-up.ps1",
    "dev:db:down": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/db-down.ps1",
    "dev:db:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/db-status.ps1",
    "dev:live:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/live-start.ps1",
    "dev:live:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/live-stop.ps1",
    "dev:live:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/live-status.ps1",
    "dev:postgres:run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/postgres-runner.ps1",
    "dev:watchdog:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/watchdog-start.ps1",
    "dev:watchdog:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/watchdog-stop.ps1",
    "dev:watchdog:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/watchdog-status.ps1",
    "db:runtime-check": "node scripts/db/runtime-check.mjs",
    "qa:stage6-slots": "node scripts/qa/stage6-slot-flow-check.mjs",
    "qa:stage8-admin-bookings": "node scripts/qa/stage8-admin-bookings-flow-check.mjs",
    "qa:stage28-calendar": "node scripts/qa/stage28-calendar-flow-check.mjs",
    "qa:stage28-slot-reserve": "node scripts/qa/stage28-slot-reserve-conflict-check.mjs",
    "qa:web-booking": "node scripts/qa/web-booking-flow-check.mjs",
    "qa:google-calendar-creds": "node scripts/qa/google-calendar-credentials-check.mjs",
    "build": "corepack pnpm -r --workspace-concurrency=1 build",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "corepack pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
