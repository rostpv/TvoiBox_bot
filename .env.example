# ==========================================
# Core Application
# ==========================================
NODE_ENV=development
TZ=Europe/Moscow
APP_NAME=tvoy-box-training-scheduler
APP_HOST=0.0.0.0
APP_PORT=3000
API_LOG_LEVEL=debug
API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ==========================================
# Telegram Bot
# ==========================================
BOT_LOG_LEVEL=debug
BOT_DRY_RUN=true
ADMIN_TELEGRAM_ID=PUT_ADMIN_TELEGRAM_ID_HERE
TRAINER_TELEGRAM_ID=PUT_TRAINER_TELEGRAM_ID_HERE
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE
MINI_APP_AUTH_SECRET=PUT_YOUR_MINI_APP_AUTH_SECRET_HERE
MINI_APP_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
WEB_TRAINER_LOGIN_SECRET=PUT_LOCAL_WEB_TRAINER_LOGIN_SECRET_HERE

# ==========================================
# Database (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tvoy_box

# ==========================================
# Google Calendar
# ==========================================
GOOGLE_CALENDAR_SYNC_MODE=real
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@example.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\\nreplace-me\\n-----END PRIVATE KEY-----\\n
