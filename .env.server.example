# Unique Docker Compose stack name on the server.
# Change it for every new project so containers, volumes and networks do not overlap.
STACK_NAME=tvoy-box-bot

NODE_ENV=production
TZ=Europe/Moscow

APP_NAME=tvoy-box-training-scheduler
APP_HOST=0.0.0.0
APP_PORT=3000
API_LOG_LEVEL=info

# Publish API only on VPS localhost, not directly to the public internet.
# If another project already uses this port, pick a different one.
API_BIND_IP=127.0.0.1
API_PORT=3300
MINI_APP_BIND_IP=127.0.0.1
MINI_APP_PORT=3302
API_BASE_URL=http://api:3000
PUBLIC_API_DOMAIN=api.example.ru
PUBLIC_APP_DOMAIN=app.example.ru
NEXT_PUBLIC_API_BASE_URL=https://api.example.ru

BOT_LOG_LEVEL=info
BOT_DRY_RUN=false
BOT_DELIVERY_MODE=webhook
BOT_BIND_IP=127.0.0.1
BOT_PORT=3301
BOT_WEBHOOK_HOST=0.0.0.0
BOT_WEBHOOK_PORT=8081
BOT_WEBHOOK_PATH=/telegram/webhook/tvoy-box-secret-path
BOT_WEBHOOK_PUBLIC_URL=https://api.example.ru/telegram/webhook/tvoy-box-secret-path
BOT_WEBHOOK_SECRET_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_WEBHOOK_SECRET
ADMIN_TELEGRAM_ID=PUT_ADMIN_TELEGRAM_ID_HERE
TRAINER_TELEGRAM_ID=PUT_TRAINER_TELEGRAM_ID_HERE
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE
MINI_APP_AUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_MINI_APP_SECRET
MINI_APP_ALLOWED_ORIGINS=https://app.example.ru
WEB_TRAINER_LOGIN_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_WEB_TRAINER_SECRET

POSTGRES_DB=tvoy_box
POSTGRES_USER=tvoy_box
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
DATABASE_URL=postgresql://tvoy_box:CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD@postgres:5432/tvoy_box

GOOGLE_CALENDAR_SYNC_MODE=real
GOOGLE_CALENDAR_ID=primary

# Preferred production mode: mount the full JSON service-account file into the container.
# Create .secrets/google-service-account.json in the project root on the server from the downloaded Google JSON key.
GOOGLE_SERVICE_ACCOUNT_JSON_SOURCE=../.secrets/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/run/secrets/google-service-account.json

# Optional fallback if you do not use a JSON file.
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@example.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\\nreplace-me\\n-----END PRIVATE KEY-----\\n
