# Уникальное имя docker stack / compose project на сервере.
# Для каждого нового проекта меняй это значение, чтобы контейнеры,
# сеть и тома не пересекались между собой.
STACK_NAME=tvoy-box-bot

NODE_ENV=production
TZ=Europe/Moscow

APP_NAME=tvoy-box-training-scheduler
APP_HOST=0.0.0.0
APP_PORT=3000
API_LOG_LEVEL=info

# Публикуем API только на localhost VPS, а не наружу.
# Если на сервере уже есть другой проект, просто выбери другой порт.
API_BIND_IP=127.0.0.1
API_PORT=3300
API_BASE_URL=http://api:3000

BOT_LOG_LEVEL=info
BOT_DRY_RUN=false
ADMIN_TELEGRAM_ID=PUT_ADMIN_TELEGRAM_ID_HERE
TRAINER_TELEGRAM_ID=PUT_TRAINER_TELEGRAM_ID_HERE
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

POSTGRES_DB=tvoy_box
POSTGRES_USER=tvoy_box
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
DATABASE_URL=postgresql://tvoy_box:CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD@postgres:5432/tvoy_box

GOOGLE_CALENDAR_SYNC_MODE=real
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@example.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\\nreplace-me\\n-----END PRIVATE KEY-----\\n
