# Override file for a separate Telegram test bot on top of the already running dev contour.
# Copy to .env.server.test-bot.override on the VPS and fill in only these values.

TELEGRAM_BOT_TOKEN=PUT_TEST_BOT_TOKEN_HERE
ADMIN_TELEGRAM_ID=PUT_ADMIN_TELEGRAM_ID_HERE
TRAINER_TELEGRAM_ID=PUT_TRAINER_TELEGRAM_ID_HERE

BOT_DRY_RUN=false
BOT_DELIVERY_MODE=polling
BOT_BIND_IP=127.0.0.1
BOT_PORT=3311

BOT_MINI_APP_URL=https://app.anyatobolova.ru/
BOT_MINI_APP_LABEL=Открыть mini app
BOT_MINI_APP_TRAINER_URL=https://app.anyatobolova.ru/
BOT_MINI_APP_TRAINER_LABEL=Открыть тренерский экран

# Optional for easier diagnostics
BOT_LOG_LEVEL=info
